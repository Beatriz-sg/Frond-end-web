# Configurações da API
# Set this to your machine's IP when running on a phone or another device on the same network.
# Example for home network: VITE_API_URL=http://192.168.1.10:8080
# Do NOT include /api — the services add that prefix automatically.
VITE_API_URL=http://localhost:8080


# Configurações de ambiente
VITE_ENVIRONMENT=development

# Chaves de API externas
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
VITE_PAYMENT_GATEWAY_KEY=your_payment_gateway_key_here

# Configurações de upload
VITE_MAX_FILE_SIZE=5242880
VITE_ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp